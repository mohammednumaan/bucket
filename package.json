  "description": "bucket is a rate-limiter that implements the token-bucket algorithm, built in TypeScript.",
  "main": "index.js",
  "scripts": {
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
